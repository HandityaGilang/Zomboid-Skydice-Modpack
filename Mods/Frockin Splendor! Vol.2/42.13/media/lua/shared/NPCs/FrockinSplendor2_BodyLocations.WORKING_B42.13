require("NPCs/BodyLocations")


local group = BodyLocations.getGroup("Human")
local locations = group:getAllLocations()

local function AddOrMoveBodyLocation(name, reference, after)

    local bodyLocation = group:getOrCreateLocation(name)

   -- locations:remove(bodyLocation)

    local index = locations:indexOf(reference)
    if after then
        index = index + 1
    end

  --  locations:add(index, bodyLocation)
end

-- Insertions / reorder rules
AddOrMoveBodyLocation(FS2Registry.KIU3, ItemBodyLocation.UNDERWEAR_EXTRA1)
AddOrMoveBodyLocation(FS2Registry.KIU2, ItemBodyLocation.UNDERWEAR_EXTRA1)
AddOrMoveBodyLocation(FS2Registry.KIU1, ItemBodyLocation.UNDERWEAR_EXTRA1)
AddOrMoveBodyLocation(FS2Registry.KIU0, ItemBodyLocation.UNDERWEAR_EXTRA1)

AddOrMoveBodyLocation(FS2Registry.KIUA, ItemBodyLocation.HAT)
AddOrMoveBodyLocation(FS2Registry.KIUB, ItemBodyLocation.HAT)
AddOrMoveBodyLocation(FS2Registry.KIUC, ItemBodyLocation.HAT)

