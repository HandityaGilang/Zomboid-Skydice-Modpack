<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        Width="500" Height="500"
        CanResize="False"
        x:Class="SkydiceModpackDownloader.MainWindow"
        Title="Skydice Modpack Downloader">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Skydice Modpack Downloader" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Folder Selection -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBox Name="ModsFolderTextBox" IsReadOnly="True" Watermark="Pilih Folder Mods..." Margin="0,0,10,0"/>
            <Button Grid.Column="1" Name="SelectFolderButton" Content="Pilih Folder" Click="SelectFolderButton_Click"/>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,20">
            <Button Name="CheckButton" Content="Check" Click="CheckButton_Click" Width="100" HorizontalContentAlignment="Center"/>
            <Button Name="SyncButton" Content="Sync" Click="SyncButton_Click" Width="100" HorizontalContentAlignment="Center" IsEnabled="False"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Name="StatusTextBlock" Text="Status: Menunggu..." TextWrapping="Wrap" Margin="0,0,0,10"/>

        <!-- App Log -->
        <ListBox Grid.Row="4" Name="LogListBox" Margin="0,0,0,10" ScrollViewer.VerticalScrollBarVisibility="Auto" CornerRadius="4">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="MinHeight" Value="20"/>
                    <Setter Property="Padding" Value="5,2"/>
                </Style>
            </ListBox.Styles>
        </ListBox>

        <!-- Progress -->
        <ProgressBar Grid.Row="5" Name="DownloadProgressBar" VerticalAlignment="Bottom" Height="20" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="6" Name="ProgressTextBlock" Text="" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
    </Grid>
</Window>
